{
  "name": "@arc-lang/qrcode",
  "version": "0.1.0",
  "description": "Zero-dependency QR code generator. Inline SVG, single <path> element, pure JavaScript, ISO 18004 byte-mode versions 1–40. Works in Node.js, browsers, and Arc.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node build.js",
    "test": "node --test tests/index.test.js",
    "prepare": "node build.js"
  },
  "files": ["src/", "arc/", "dist/", "index.d.ts", "README.md", "LICENSE"],
  "keywords": [
    "qrcode", "qr", "qr-code", "svg", "generator", "encoder",
    "javascript", "zero-dependency", "arc", "arc-lang", "iso18004"
  ],
  "license": "MIT",
  "engines": { "node": ">=18" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KCuppens/arc-qrcode.git"
  },
  "bugs": {
    "url": "https://github.com/KCuppens/arc-qrcode/issues"
  },
  "homepage": "https://github.com/KCuppens/arc-qrcode#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/KCuppens"
  }
}

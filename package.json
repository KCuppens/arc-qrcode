{
  "name": "@arc-lang/qrcode",
  "version": "0.1.0",
  "description": "Zero-dependency QR code generator. Inline SVG, single <path> element, byte-mode ISO 18004 versions 1–40.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "types": "./index.d.ts"
    }
  },
  "scripts": {
    "build": "node build.js",
    "test": "node --test tests/index.test.js"
  },
  "files": ["src/", "arc/", "dist/", "index.d.ts"],
  "keywords": ["qrcode", "qr", "svg", "zero-dependency", "arc", "arc-lang"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KCuppens/arc-qrcode.git"
  },
  "homepage": "https://github.com/KCuppens/arc-qrcode#readme"
}
